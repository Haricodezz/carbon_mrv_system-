# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/carbon_mrv

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-a-long-random-string

# ── Google Earth Engine ───────────────────────────────────────────────────────
GEE_PROJECT=carboncredits-487906
# Paste the FULL contents of your GCP service-account JSON key below (one line):
GEE_SERVICE_ACCOUNT_JSON=

# Alternative: path to JSON key file (useful for local dev)
# GEE_SERVICE_ACCOUNT_KEY_PATH=/path/to/gee-service-account.json

# ── Blockchain / Polygon ─────────────────────────────────────────────────────
PRIVATE_KEY=your-wallet-private-key
CONTRACT_ADDRESS=0xac9b428132898610873682700b0ae73182506e3b
RPC_URL=https://rpc-amoy.polygon.technology
PLATFORM_WALLET_ADDRESS=0x7f3846D0c4524Bf27d32019C9DBda08876427f5D

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=carboncreditcct@gmail.com
SMTP_PASSWORD=your-16-char-gmail-app-password
